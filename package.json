{
  "name": "plasma-engine",
  "version": "0.2.0",
  "description": "AI Persona Engine — LLM-backed human simulation with memory, emotion, fatigue, social influence, and relationship graphs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "ai", "persona", "llm", "simulation", "game", "npc",
    "emotion", "memory", "social-graph", "mcp", "anthropic", "openai"
  ],
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true },
    "openai": { "optional": true }
  },
  "dependencies": {
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "openai": "^4.78.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.d.ts"]
  }
}
